# Frontend production env template.
# NEXT_PUBLIC_* vars are baked at BUILD time (next build).
# In Docker, this is passed via --build-arg in docker-compose.prod.yml,
# NOT loaded from this file at runtime.
#
# This file documents what the build expects so a developer can also
# `pnpm build` locally with the prod URL when smoke-testing.

NEXT_PUBLIC_API_URL=https://lablens.ainative.build
