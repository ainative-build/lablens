# LabLens — production env template.
# Copy to .env.production on the ECS box, populate real values.
# NEVER commit .env.production (gitignored via .env*).

# ── Required ───────────────────────────────────────────────────────────────
LABLENS_DASHSCOPE_API_KEY=sk-replace-with-real-key

# CORS — pydantic-settings parses JSON arrays from env.
# Lock to your real prod origin to prevent CSRF-from-other-domains.
LABLENS_ALLOWED_ORIGINS=["https://lablens.ainative.build"]

# ── App ────────────────────────────────────────────────────────────────────
LABLENS_APP_ENV=production
LABLENS_LOG_LEVEL=INFO
LABLENS_MAX_UPLOAD_SIZE_MB=20

# ── Optional — DashScope tunables (defaults usually fine) ──────────────────
# LABLENS_DASHSCOPE_API_BASE=https://dashscope-intl.aliyuncs.com/api/v1
# LABLENS_DASHSCOPE_OCR_MODEL=qwen-vl-ocr
# LABLENS_DASHSCOPE_CHAT_MODEL=qwen-plus

# ── Optional — Alibaba GDB (graph enrichment, not used in v1) ──────────────
# LABLENS_GDB_HOST=
# LABLENS_GDB_PORT=8182
# LABLENS_GDB_USERNAME=
# LABLENS_GDB_PASSWORD=

# ── Optional — DashVector (embeddings, not used in v1) ─────────────────────
# LABLENS_DASHVECTOR_API_KEY=
# LABLENS_DASHVECTOR_ENDPOINT=
